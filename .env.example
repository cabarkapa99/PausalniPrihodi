# ============================================================================
# Paušalni Prihodi — website (Next.js + Payload CMS) env template.
# Copy to .env for local dev; set these in Coolify's UI in production.
# ============================================================================

# -- Core (needed at BUILD and runtime) --------------------------------------
# Payload signing secret. Generate via `openssl rand -hex 32`.
PAYLOAD_SECRET=
# CMS database (Neon Postgres). Build prerenders the homepage from it.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
# Public site URL. NEXT_PUBLIC_ is baked into the client bundle at build time.
SITE_URL=https://pausalni-prihodi.com
NEXT_PUBLIC_SITE_URL=https://pausalni-prihodi.com

# -- Runtime only ------------------------------------------------------------
# Secret guarding the on-demand revalidation route.
REVALIDATE_SECRET=
# Contact-form recipient.
CONTACT_EMAIL=

# Mail (contact form)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# -- S3 media storage --------------------------------------------------------
# Same bucket + credentials as the invoice app; media is namespaced under the
# `website-media/` prefix. Leave S3_BUCKET blank to fall back to local disk.
S3_BUCKET=
S3_REGION=eu-north-1
S3_ENDPOINT=https://s3.eu-north-1.amazonaws.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
